{
    "camera": {
        
        "driver": "pi",
        "id": "CAM01",
        "width": 4056,
        "height": 3040,
        "format": "JPEG",
        "quality": 95,
        "auto_white_balance": true,
        "auto_exposure": true,
        "analogue_gain": 1.0,
        "exposure_time": 10000,
        "warmup_time": 2
    },

    "storage": {
        "directory": "../images"
    },

    "logging": {
        "directory": "../logs",
        "level": "INFO"
    },

    "serial": {
        "enabled": false,
        "port": "COM5",
        "baud_rate": 115200,
        "timeout": 1
    },

    
    "communication":
    {
        "mode": "menue",
        

        "network":
        {
            "host": "0.0.0.0",
            "port": 5000
        },

        "serial":
        {
            "port": "/dev/ttyGS0",
            "baudrate": 115200
        }
    },

    "ui":
    {
        "mode":"menu"
    }
    
}